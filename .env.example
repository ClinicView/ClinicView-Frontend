# frontend/.env.example — variables para desarrollo local SIN Docker
# Copia como frontend/.env.local y ajusta si el backend corre en otro puerto.
#
# Variables NEXT_PUBLIC_* se exponen al navegador — nunca pongas secretos aquí.

# URL base de la API del backend, tal como la ve el navegador del usuario.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
